#!/usr/bin/env python3

import asyncio
import sys

from flud.FludConfig import FludConfig
from flud.FludScheduler import FludScheduler
from flud.protocol.AsyncLocalClient import AsyncLocalClient


async def _main():
    config = FludConfig()
    config.load(doLogging=False)

    if len(sys.argv) == 2:
        config.clientport = int(sys.argv[1])

    print("connecting to localhost:%d" % config.clientport)
    client = AsyncLocalClient(config)
    await client.connect()
    scheduler = FludScheduler(config, client)
    try:
        await scheduler.run_forever()
    finally:
        await client.close()


if __name__ == "__main__":
    asyncio.run(_main())
