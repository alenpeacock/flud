#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export PATH="$SCRIPT_DIR:$PATH"

testhost="${FLUDTESTHOST:-127.0.0.1}"
tacfile=`tacpath-flud`
if [ -z "$tacfile" ]; then
    tacfile="$SCRIPT_DIR/tacpath-flud"
    tacfile=$("$tacfile")
fi
if [ -z "$tacfile" ]; then
    echo "could not determine FludNode.tac path" >&2
    exit 1
fi
startup_timeout=${FLUDSTARTUPTIMEOUT:-30}
use_async_server="${FLUD_ASYNCIO_SERVER:-0}"

wait_for_node() {
    local pid="$1"
    local port="$2"
    local logfile="$3"
    local deadline=$((SECONDS + startup_timeout))
    while (( SECONDS < deadline )); do
        if ! kill -0 "$pid" 2>/dev/null; then
            echo "node process $pid exited before opening port $port" >&2
            if [ -f "$logfile" ]; then
                tail -n 40 "$logfile" >&2
            fi
            return 1
        fi
        if nc -z 127.0.0.1 "$port" >/dev/null 2>&1; then
            return 0
        fi
        sleep 0.2
    done
    echo "timed out after ${startup_timeout}s waiting for node $pid to listen on $port" >&2
    if [ -f "$logfile" ]; then
        tail -n 40 "$logfile" >&2
    fi
    return 1
}

start_node() {
    local listenport="$1"
    local pidfile="$2"
    local logfile="$3"
    local gateway_host="$4"
    local gateway_port="$5"

    rm -f "$pidfile"

    if [ "$use_async_server" = "1" ]; then
        local cmd=(poetry run python3 "$SCRIPT_DIR/fludnode")
        if [ -n "$gateway_host" ] && [ -n "$gateway_port" ]; then
            cmd+=("$gateway_host" "$gateway_port" "$listenport")
        else
            cmd+=("$listenport")
        fi
        echo "starting {$FLUDHOME} ${cmd[*]} on $listenport"
        FLUDPORT=$listenport "${cmd[@]}" >"$logfile" 2>&1 &
        local pid=$!
        echo "$pid" > "$pidfile"
        pids[$i]=$pid
        return 0
    fi

    local cmd=(poetry run twistd -noy "$tacfile" --pidfile="$pidfile" --logfile="$logfile")
    if [ -n "$gateway_host" ] && [ -n "$gateway_port" ]; then
        echo "starting {$FLUDHOME} ${cmd[*]} on $listenport to $gateway_host:$gateway_port"
        FLUDGWHOST=$gateway_host FLUDGWPORT=$gateway_port FLUDPORT=$listenport \
            "${cmd[@]}" &
    else
        echo "starting {$FLUDHOME} ${cmd[*]} on $listenport"
        FLUDPORT=$listenport "${cmd[@]}" &
    fi
    pids[$i]=$!
    return 0
}

if [ -z ${FLUDSTART} ]; then
    i=1
else
    i=${FLUDSTART}
fi

NODES=${1:-1}

if [ -n "$3" ]; then
    boothost=$2
    bootport=$3
fi

export FLUDHOME="${HOME}/.flud${i}"
if [ ! -d $FLUDHOME ]; then
    mkdir $FLUDHOME;
fi
let listenport=8080+$i
pidfile="$FLUDHOME/twistd.pid"
logfile="$FLUDHOME/twistd.log"
start_node "$listenport" "$pidfile" "$logfile" "$boothost" "$bootport"
if ! wait_for_node "${pids[$i]}" "$listenport" "$logfile"; then
    exit 1
fi

if [[ "$NODES" =~ ^[0-9]+-[0-9]+$ ]]; then
    seqstart=$(( ${NODES%-*} + 1 ))
    seqend=${NODES#*-}
else
    let seqstart=$i+1
    let seqend=$NODES+$i-1
fi

for i in `seq $seqstart $seqend`; do
    export FLUDHOME="${HOME}/.flud${i}"
    if [ ! -d $FLUDHOME ]; then
        mkdir $FLUDHOME;
    fi
    testport=$listenport
    let listenport=8080+$i
    pidfile="$FLUDHOME/twistd.pid"
    logfile="$FLUDHOME/twistd.log"
    start_node "$listenport" "$pidfile" "$logfile" "$testhost" "$testport"
    if ! wait_for_node "${pids[$i]}" "$listenport" "$logfile"; then
        exit 1
    fi
done
